<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:AgendaSQLite"
             x:Class="AgendaSQLite.MainPage"
             Title="AgendaSQLoza">

    <Grid RowDefinitions="Auto,*,Auto"
          Padding="5">

        <!-- Barra de búsqueda -->
        <SearchBar Grid.Row="0"
                   Text="{Binding SearchText}"
                   SearchCommand="{Binding SearchCommand}"
                   Placeholder="Buscar contacto por nombre o teléfono..."/>

        <!-- Lista de contactos con SwipeView para eliminar -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Contacts}"
                        SelectionMode="Single"
                        SelectionChangedCommand="{Binding EditContactCommand}"
                        SelectionChangedCommandParameter="{Binding SelectedItem, Source={RelativeSource Self}}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:Contact">
                    <SwipeView>

                        <!-- Acción deslizar izquierda para eliminar -->
                        <SwipeView.RightItems>
                            <SwipeItem Text="Eliminar"
                                       BackgroundColor="Red"
                                       Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:ContactsViewModel}},
                                                 Path=DeleteContactCommand}"
                                       CommandParameter="{Binding .}"/>
                        </SwipeView.RightItems>

                        <!-- Contenido del item -->
                        <Grid Padding="15,10"
                              ColumnDefinitions="Auto,*"
                              RowDefinitions="Auto,Auto">

                            <!-- Avatar circular -->
                            <Border Grid.RowSpan="2"
                                    BackgroundColor="SteelBlue"
                                    StrokeShape="RoundRectangle 25"
                                    WidthRequest="50"
                                    HeightRequest="50"
                                    VerticalOptions="Center"
                                    Margin="0,0,15,0">
                                <Label Text="{Binding Name[0]}"
                                       TextColor="White"
                                       FontSize="22"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"/>
                            </Border>

                            <!-- Nombre -->
                            <Label Grid.Column="1"
                                   Grid.Row="0"
                                   Text="{Binding Name}"
                                   FontSize="18"
                                   FontAttributes="Bold"/>

                            <!-- Teléfono -->
                            <Label Grid.Column="1"
                                   Grid.Row="1"
                                   Text="{Binding Phone}"
                                   FontSize="14"
                                   TextColor="Gray"/>
                        </Grid>
                    </SwipeView>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <!-- Vista cuando no hay contactos -->
            <CollectionView.EmptyView>
                <Label Text="No hay contactos. ¡Agrega uno!"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       FontSize="16"
                       TextColor="Gray"
                       Margin="0,50"/>
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- Botón agregar nuevo contacto -->
        <Button Grid.Row="2"
                Text="Nuevo Contacto"
                Command="{Binding NewContactCommand}"
                BackgroundColor="Green"
                TextColor="White"
                Margin="10"/>

    </Grid>

</ContentPage>
