<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ClimaApp.MainPage"
             Title="Clima App">

       <VerticalStackLayout Spacing="15"
                            Padding="20">

              <!-- Título -->
              <Label Text="CLIMA ACTUAL"
                     FontSize="28"
                     FontAttributes="Bold"
                     HorizontalOptions="Center"/>

              <!-- Condición climática - enlazada al modelo -->
              <Label Text="{Binding Condition}"
                     FontSize="24"
                     HorizontalOptions="Center"/>

              <!-- Grid con temperatura y humedad -->
              <Grid ColumnDefinitions="*,*"
                    Margin="0,20">

                     <!-- Temperatura -->
                     <VerticalStackLayout>
                            <Label Text="Temperatura"
                                   FontSize="14"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding Temperature, StringFormat='{0:F1}°C'}"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                     </VerticalStackLayout>

                     <!-- Humedad -->
                     <VerticalStackLayout Grid.Column="1">
                            <Label Text="Humedad"
                                   FontSize="14"
                                   HorizontalOptions="Center"/>
                            <Label Text="{Binding Humidity, StringFormat='{0}%'}"
                                   FontSize="32"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"/>
                     </VerticalStackLayout>

              </Grid>

              <!-- Botón actualizar clima -->
              <Button Text="Actualizar Clima"
                      Clicked="OnActualizarClicked"
                      BackgroundColor="Orange"
                      TextColor="White"
                      Margin="0,20"/>

       </VerticalStackLayout>

</ContentPage>
