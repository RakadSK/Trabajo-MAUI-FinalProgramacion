<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodel="clr-namespace:ListaTareas"
             x:Class="ListaTareas.MainPage"
             Title="Lista de Tareas">

    <Grid RowDefinitions="Auto,Auto,*"
            Padding="10">

        <!-- Título -->
        <Label Grid.Row="0"
               Text=" MIS TAREAS"
               FontSize="24"
               FontAttributes="Bold"
               HorizontalOptions="Center"
               Margin="0,10"/>

        <!-- Sección para agregar nueva tarea -->
        <Grid Grid.Row="1"
              ColumnDefinitions="*,Auto"
              Margin="0,10">
            <Entry Grid.Column="0"
                   Text="{Binding NewTaskName}"
                   Placeholder="Nueva tarea..."
                   ReturnCommand="{Binding AddTaskCommand}"/>
            <Button Grid.Column="1"
                    Text="Añadir"
                    Command="{Binding AddTaskCommand}"
                    BackgroundColor="Green"
                    TextColor="White"
                    Margin="5,0,0,0"/>
        </Grid>

        <!-- Lista de tareas con CollectionView -->
        <CollectionView Grid.Row="2"
                        ItemsSource="{Binding Tasks}"
                        SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewmodel:TaskItem">
                    <Grid Padding="10"
                          ColumnDefinitions="Auto,*,Auto">

                        <!-- Checkbox de completado -->
                        <CheckBox IsChecked="{Binding IsCompleted}"
                                  VerticalOptions="Center"/>

                        <!-- Nombre de la tarea con tachado si está completada -->
                        <Label Grid.Column="1"
                               Text="{Binding Name}"
                               FontSize="16"
                               VerticalOptions="Center"
                               Margin="10,0">
                            <Label.Triggers>
                                <DataTrigger TargetType="Label"
                                             Binding="{Binding IsCompleted}"
                                             Value="True">
                                    <Setter Property="TextDecorations"
                                            Value="Strikethrough"/>
                                    <Setter Property="TextColor"
                                            Value="Gray"/>
                                </DataTrigger>
                            </Label.Triggers>
                        </Label>

                        <!-- Botón eliminar tarea -->
                        <Button Grid.Column="2"
                                Text="🗑️"
                                Command="{Binding Source={RelativeSource AncestorType={x:Type viewmodel:MainViewModel}},
                                          Path=DeleteTaskCommand}"
                                CommandParameter="{Binding .}"
                                BackgroundColor="Transparent"
                                TextColor="Red"/>
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

    </Grid>

</ContentPage>
